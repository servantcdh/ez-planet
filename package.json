{
  "name": "ez-planet-canvas",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:labeling": "npm run build -w @servantcdh/ez-planet-labeling",
    "build:cosmos": "npm run build -w @servantcdh/ez-planet-cosmos",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
